NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1

BACKEND_PUBLIC_URL=https://your-domain.com
FRONTEND_PUBLIC_URL=https://your-domain.com
APP_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

POSTGRES_DB=adticks
POSTGRES_USER=adticks
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg://adticks:replace-with-a-strong-database-password@postgres:5432/adticks

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_PATH=/api/v1/auth/google/callback
