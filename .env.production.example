NEXT_PUBLIC_API_URL=https://adticks.com/api/v1
NEXT_PUBLIC_APP_URL=https://app.adticks.com

BACKEND_PUBLIC_URL=https://adticks.com
FRONTEND_PUBLIC_URL=https://app.adticks.com
FRONTEND_MARKETING_URL=https://adticks.com
FRONTEND_APP_ORIGINS=https://app.adticks.com
APP_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
SESSION_COOKIE_DOMAIN=.adticks.com

POSTGRES_DB=adticks
POSTGRES_USER=adticks
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg://adticks:replace-with-a-strong-database-password@postgres:5432/adticks

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_PATH=/api/v1/auth/google/callback
